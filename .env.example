# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# GOOGLE_API_KEY: Optional fallback key for Google Custom Search API
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# GOOGLE_CX: Optional fallback Google Custom Search Engine ID
GOOGLE_CX=YOUR_GOOGLE_CX

# GROQ_API_KEY: Optional fallback key for GROQ API
GROQ_API_KEY=YOUR_GROQ_API_KEY

# EXA_API_KEY: Optional fallback key for Exa AI Neural Search API
EXA_API_KEY=YOUR_EXA_API_KEY
